# Скопируйте в .env и заполните (файл .env в git не попадает).
# На сервере: cp .env.example .env && nano .env

# Обязательно для docker compose (раньше подставлялся небезопасный дефолт).
DB_PASSWORD=

# Опционально: без ключа сид дефолтного админа пропускается.
DEFAULT_ADMIN_API_KEY=
DEFAULT_ADMIN_NAME=admin

DB_USER=locator_user
DB_NAME=locator_db
DB_PORT=5432
DB_SSLMODE=disable

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

BASE_URL=http://localhost:8080
GIN_MODE=release

# OSRM match API, без завершающего /
# ROUTING_BASE_URL=
