# Скопируйте в .env и заполните (файл .env в git не попадает).
# На сервере: cp .env.example .env && nano .env

# Обязательно для docker compose (раньше подставлялся небезопасный дефолт).
DB_PASSWORD=

# Опционально: без ключа сид дефолтного админа пропускается.
DEFAULT_ADMIN_API_KEY=
DEFAULT_ADMIN_NAME=admin

DB_USER=locator_user
DB_NAME=locator_db
DB_PORT=5432
DB_SSLMODE=disable

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

BASE_URL=http://localhost:8080
GIN_MODE=release

# Docker BuildKit/buildx: локальный cache и лимит на диске (см. scripts/docker-build.sh)
BUILDX_CACHE_DIR=/var/cache/locator-buildx
BUILDX_KEEP_STORAGE=3gb

# OSRM: трек по дорогам на карте («Путь по дорогам»). Без завершающего /.
# Работает сразу — публичный сервер (лимит ~10 точек на запрос):
ROUTING_BASE_URL=https://router.project-osrm.org
ROUTING_MATCH_CHUNK_SIZE=10
ROUTING_MATCH_RADIUS=20
# Свой OSRM (быстрее, без лимитов): ./scripts/setup_osrm.sh && docker compose --profile osrm-local up -d osrm
# ROUTING_BASE_URL=http://osrm:5000
# ROUTING_MATCH_CHUNK_SIZE=50
# ROUTING_MATCH_RADIUS=25
